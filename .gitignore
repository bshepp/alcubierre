# Sweep outputs (large parquet + per-run config snapshots).
# Keep the directory placeholder so the layout is reproducible.
sweeps/*.parquet
sweeps/*.config.json
!sweeps/.gitkeep

# Local working copies of sweep results downloaded from HF Dataset
# bshepp/alcubierre-sweeps. Re-fetchable via `hf download`.
sweeps_remote/

